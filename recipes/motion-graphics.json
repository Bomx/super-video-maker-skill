{
  "id": "motion-graphics",
  "name": "Motion Graphics",
  "version": "1.0.0",
  "description": "Programmatic launch or explainer video using Remotion React timelines or HyperFrames HTML-native compositions with FFmpeg audio finish.",
  "best_for": [
    "product launch teasers",
    "kinetic typography explainers",
    "UI mockup animations",
    "deterministic ad variant renders"
  ],
  "not_for": [
    "agent-operated browser proof",
    "phone-native UGC ads",
    "raw screencast demos without motion design"
  ],
  "platforms": ["youtube", "linkedin", "website", "ads"],
  "aspect_ratios": ["16:9", "9:16", "1:1"],
  "duration_seconds": { "min": 10, "max": 120, "target": 45 },
  "stages": [
    {
      "id": "intake",
      "title": "Creative brief",
      "actions": [
        "Choose Remotion or HyperFrames engine",
        "Define scenes, typography, brand colors, and CTA"
      ],
      "artifacts": ["creative_brief.json", "scene_list.json"]
    },
    {
      "id": "build",
      "title": "Composition build",
      "actions": [
        "Implement scenes in remotion-template or hyperframes-template",
        "Preview in studio or browser"
      ],
      "artifacts": ["compositions/", "public/render-props.json"]
    },
    {
      "id": "render",
      "title": "Programmatic render",
      "actions": [
        "Render MP4 from composition",
        "Add voiceover, music, or captions with FFmpeg if not in template"
      ],
      "artifacts": ["final/motion_master.mp4"],
      "paid_generation": false
    },
    {
      "id": "qc",
      "title": "QC",
      "actions": [
        "Run ffmpeg_qc",
        "Check text safe zones and no clipped UI"
      ],
      "artifacts": ["final/motion_master.mp4"]
    }
  ],
  "tools": [
    "tools/video_orchestrator.py",
    "tools/video_captioner.py",
    "tools/music_provider.py",
    "tools/ffmpeg_qc.py"
  ],
  "providers": {
    "motion": "remotion_or_hyperframes",
    "audio": "elevenlabs_optional",
    "finish": "ffmpeg"
  },
  "routing_keywords": [
    "motion graphics",
    "remotion",
    "hyperframes",
    "kinetic text",
    "launch video",
    "animated explainer"
  ],
  "routing_negative_keywords": ["screen recording demo", "heygen avatar", "seedance ugc"],
  "visual_jobs": ["mechanism", "action", "transition"],
  "qc_checks": [
    "text stays inside safe margins",
    "yuv420p h264 output",
    "no black frames at scene joins"
  ],
  "deliverables": ["final/motion_master.mp4", "job_state.json"]
}
